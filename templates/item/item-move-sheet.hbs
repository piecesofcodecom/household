<div class="item-sheet">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-action="editImage" data-field="img" title="{{item.name}}" />
    <div class="header-fields">
      <input class="item-name" name="name" type="text" value="{{item.name}}" placeholder="Name" data-dtype="String" />
      <div class="grid grid-4col" style="width: 100px">
        {{#each item.system.suits as | value key | }}
        <div class="resource">
          <input type="radio" class="radio-suit-{{key}} no-decor" data-action="customEdit" data-value="{{value}}"
            data-path="system.suits.{{key}}" data-dtype="Boolean" id="choose-{{key}}-{{../item.id}}" {{#if value}}
            checked {{/if}} />
        </div>
        {{/each}}
      </div>
    </div>
  </header>
  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-action="tab" data-tab="description" data-group="primary">{{localize
      "HOUSEHOLD.SheetLabels.General"}}</a>
  </nav>
  {{!-- Sheet Body --}}
  <section class="sheet-body">
    {{!-- Description Tab --}}
    <div class="tab {{tabs.description.cssClass}}" data-group="primary" data-tab="description">
      <br />
      <label class="resource-label">{{localize "HOUSEHOLD.SheetLabels.Requirements"}}</label>
      <input class="" type="text" name="system.requirements" value="{{system.requirements}}" data-dtype="String" />
      {{!-- To render inline rolls in a TinyMCE editor, you need to pass the parent actor's (if any) roll data to the
      rollData prop. --}}
      <br />
      <br />
      <label class="resource-label">{{localize "HOUSEHOLD.SheetLabels.Description"}}</label>
      <div class="text-editor" style="height: 200px;">
        {{#if editable}}
        <prose-mirror name="system.description" button="true" editable="{{editable}}" toggled="false"
          value="{{system.description}}">
          {{{descriptionHTML}}}
        </prose-mirror>
        {{else}}
        {{{descriptionHTML}}}
        {{/if}}
      </div>
    </div>
  </section>
</div>

{{log system}}