<div class="item-sheet">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-action="editImage" data-field="img" title="{{item.name}}" />
    <div class="header-fields">
      <input class="item-name" name="name" type="text" value="{{item.name}}" placeholder="Name" data-dtype="String" />
      <div class="grid grid-6col">
        <div class="resource grid-5col">
          <label class="resource-label">{{localize "HOUSEHOLD.Trait.long"}}</label>
          <input class="" type="text" name="system.trait" value="{{system.trait}}" data-dtype="String" />
        </div>
        <div class="resource">
          <label class="resource-label">{{localize "HOUSEHOLD.Price.long"}}</label>
          <input type="text" name="system.price" value="{{system.price}}" data-dtype="Number" />
        </div>
      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-action="tab" data-tab="description" data-group="primary">{{localize
      "HOUSEHOLD.SheetLabels.General"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Description Tab --}}
    <div class="tab {{tabs.description.cssClass}}" data-group="primary" data-tab="description">
      {{!-- To render inline rolls in a TinyMCE editor, you need to pass the parent actor's (if any) roll data to the
      rollData prop. --}}
      <br />
      <div style="display: grid;
  grid-gap: 10px;
  grid-template-columns: 3fr 6fr; gap 5px">

        <div style="border: 0px solid #000">
          <div class="flexrow">
            <label class="resource-label">{{localize "HOUSEHOLD.SheetLabels.Type"}}</label>
            <input type="text" name="system.type" value="{{system.type}}" data-dtype="String" />
          </div>
          <div class="flexrow">
            <label class="resource-label">{{localize "HOUSEHOLD.Skill.long"}}</label>
            <input type="text" name="system.skill" value="{{system.skill}}" data-dtype="String" />
          </div>
          <br />
          <div class="flexrow">

            {{#each fields as | fd key | }}
            {{#when fd 'eq' ../system.field}}
            <input type="checkbox" class="fa-household-{{getSuitFromField fd}}-full no-decor" data-action="customEdit"
              data-value="{{fd}}" data-path="system.field" data-dtype="String" id="choose-{{fd}}" checked />
            {{else}}
            <input type="checkbox" class="fa-household-{{getSuitFromField fd}} no-decor" data-action="customEdit"
              data-value="{{fd}}" data-path="system.field" data-dtype="String" id="choose-{{fd}}" />
            {{/when}}
            {{/each}}
          </div>
        </div>
        <div style="border: 0px solid #000; min-height: 200px;">
          <label class="resource-label">{{localize "HOUSEHOLD.SheetLabels.Description"}}</label>

          <div class="text-editor" style="height: 230px;">
            {{#if editable}}
            <prose-mirror name="system.description" button="true" editable="{{editable}}" toggled="false"
              value="{{system.description}}">
              {{{descriptionHTML}}}
            </prose-mirror>
            {{else}}
            {{{descriptionHTML}}}
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </section>

  {{log system}}
</div>