<nav class="combat-controls" data-tooltip-direction="UP">
  {{#if hasCombat}}
    {{#if user.isGM}}
      {{#if combat.round}}
        <button type="button" class="inline-control combat-control" data-action="nextTurn"
          data-tooltip aria-label="Next">
          <i class="fa-solid fa-forward-step" inert></i>
          <span>Next Turn</span></button>
        
        <button type="button" class="inline-control combat-control combat-control-lg" data-action="endCombat">
          <i class="fa-solid fa-stop" inert></i>
          <span>{{ localize "COMBAT.End" }}</span>
        </button>
      {{else}}
        <button type="button" class="inline-control combat-control combat-control-lg" data-action="startCombat">
          <i class="fa-solid fa-swords" inert></i>
          <span>{{ localize "COMBAT.Begin" }}</span>
        </button>
      {{/if}}
    {{else}}
      {{#if hasTurn}}
        <button type="button" class="inline-control combat-control combat-control-lg" data-action="hasFinished">
          <i class="fa-solid fa-check"></i>
          <span>End</span>
        </button>
      {{/if}}
    {{/if}}
  {{/if}}
</nav>