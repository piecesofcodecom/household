<div class="flexcol">
  <h2 class="characteristic-title ">{{localize "HOUSEHOLD.AcesSleeve.long"}}</h2>
</div>
{{#each system.aces as | value key|}}
<input id="aces-{{key}}-{{../id}}" class="input-hidden custom-edit" data-object="actor" type="radio" max="2"
  data-dtype="Boolean" data-path="system.aces.{{key}}" data-value="{{value}}" />
{{/each}}
<div class="" style="height: 70px; 
  justify-content: center; margin-left: 20%; padding-top: 5px; border: 0px solid #000">

  <label for="aces-hearts-{{id}}" class="aces-card aces-card-1">

    {{#if system.aces.hearts}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-hearts-filled.png">
    {{else}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-hearts.png">
    {{/if}}
  </label>

  <label for="aces-diamonds-{{id}}" class="aces-card aces-card-2">
    {{#if system.aces.diamonds}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-diamonds-filled.png">
    {{else}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-diamonds.png">
    {{/if}}
  </label>
  <label for="aces-clubs-{{id}}" class="aces-card aces-card-3">
    {{#if system.aces.clubs}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-clubs-filled.png">
    {{else}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-clubs.png">
    {{/if}}
  </label>
  <label for="aces-spades-{{id}}" class="aces-card aces-card-4">
    {{#if system.aces.spades}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-spades-filled.png">
    {{else}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-spades.png">
    {{/if}}
  </label>
  <label for="aces-joker-{{id}}" class="aces-card aces-card-5">
    {{#if system.aces.joker}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-joker-filled.png">
    {{else}}
    <img class="aces-card-img" src="/systems/household/assets/sheet/ace-joker.png">
    {{/if}}
  </label>
</div>
<h2 class="characteristic-title" style="text-align: center;">{{localize "HOUSEHOLD.Moves.long"}}</h2>
{{> "systems/household/templates/actor/char/parts/actor-list-items.hbs" items=moves type='move'}}



<h2 class="characteristic-title" style="text-align: center;">{{localize "HOUSEHOLD.Contracts.long"}}</h2>
{{> "systems/household/templates/actor/char/parts/actor-list-items.hbs" items=contracts type='contract'}}

<h2 class="characteristic-title">{{localize "HOUSEHOLD.TTT.long"}}</h2>
<div class="flexrow">
  {{#numLoop 5}}

  {{#when ../system.ttt 'gteq' this}}
  <div style="background: url(/systems/household/assets/sheet/ttt{{this}}-filled.svg) !important;
    background-repeat: no-repeat !important;
    background-size: cover !important;
    -webkit-filter: none !important; width: 20px; height: 20px;">
    <input type="radio" id="ttt-{{this}}-{{../id}}" value="{{reduceBy this 1}}" name="system.ttt"
      data-dtype="Number">
  </div>
  {{else}}
  <div style="background: url(/systems/household/assets/sheet/ttt{{this}}.svg) !important;
    background-repeat: no-repeat !important;
    background-size: cover !important;
    -webkit-filter: none !important; width: 20px; height: 20px;">
    <input class="input-hidden" type="radio" id="ttt-{{this}}-{{../id}}" value="{{this}}" name="system.ttt"
      data-dtype="Number">
  </div>
  {{/when}}

  {{/numLoop}}
</div>