    <input type="checkbox" class="input-conditions" id="condition-tired-{{id}}" data-action="customEdit"
      data-path="system.conditions.tired" data-value="{{system.conditions.tired}}" data-object="actor"
      data-dtype="Boolean" {{doCheck system.conditions.tired}}>
    <label for="condition-tired-{{id}}">{{localize "HOUSEHOLD.Conditions.Tired"}}</label>
  </div>
  <!-- end tired -->
  <!-- broken -->
  <div>
    <input type="checkbox" class="input-conditions" id="condition-broken-{{id}}" data-action="customEdit"
      data-path="system.conditions.broken" data-value="{{system.conditions.broken}}" data-object="actor"
      data-dtype="Boolean" {{doCheck system.conditions.broken}}>
    <label for="condition-broken-{{id}}">{{localize "HOUSEHOLD.Conditions.Broken"}}</label>
  </div>
  <!-- end broken -->
  <!-- hurt -->
  <div>
    <input type="checkbox" class="fa-household-club{{#if system.conditions.hurt}}-full{{/if}} no-decor"
      id="condition-hurt-{{id}}" data-action="customEdit" data-path="system.conditions.hurt"
      data-value="{{system.conditions.hurt}}" data-object="actor" data-dtype="Boolean" {{doCheck
      system.conditions.hurt}}>
    <label for="condition-hurt-{{id}}">{{localize "HOUSEHOLD.Conditions.Hurt"}}</label>
  </div>
  <!-- end hurt -->
  <!-- sick -->
  <div>
    <input type="checkbox" class="input-conditions" id="condition-sick-{{id}}" data-action="customEdit"
      data-path="system.conditions.sick" data-value="{{system.conditions.sick}}" data-object="actor"
      data-dtype="Boolean" {{doCheck system.conditions.sick}}>
