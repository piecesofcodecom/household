<!--Stress-->
<h2 class="characteristic-title" style="text-align: center; margin-top: 10px;">{{localize "HOUSEHOLD.Stress.long"}}</h2>
<div class="flexrow">
  {{#numLoop system.stress.max}}
  <div class=''>
    {{#when ../system.stress.current 'gteq' this}}
    {{#when this 'eq' ../system.stress.danger}}
    <input id="stress-{{this}}-{{../id}}" class="input-hidden" type="radio" max="2" name="system.stress.current"
      value="{{reduceBy this 1}}" data-dtype="Number"/>
    <label class="label-stress stress-rosette-damage" for="stress-{{this}}-{{../id}}">
    </label>
    {{else}}
    <input id="stress-{{this}}-{{../id}}" class="input-hidden" type="radio" max="2" name="system.stress.current"
      value="{{reduceBy this 1}}" data-dtype="Number"/>
    <label class="label-stress stress-square-damage" for="stress-{{this}}-{{../id}}">
    </label>
    {{/when}}
    {{else}}
    {{#when this 'eq' ../system.stress.danger}}
    <input id="stress-{{this}}-{{../id}}" class="input-hidden" type="radio" max="2" name="system.stress.current"
      value="{{this}}" data-dtype="Number"/>
    <label class="label-stress stress-rosette" for="stress-{{this}}-{{../id}}"> </label>
    {{else}}
    <input id="stress-{{this}}-{{../id}}" class="input-hidden" type="radio" max="2" name="system.stress.current"
      value="{{this}}" data-dtype="Number"/>
    <label class="label-stress stress-square" for="stress-{{this}}-{{../id}}"> </label>
    {{/when}}
    {{/when}}
  </div>
  {{/numLoop}}
</div>

<!-- Decorum -->
<h2 class="characteristic-title">{{localize "HOUSEHOLD.Decorum.long"}}</h2>

<div class=" grid-decorum  flex-group-center ">
  <div class=" decorum_1 decorum">
    <input type="radio" class="no-decor" id="decorum_1-{{id}}" data-value="1"
      data-dtype="Number" data-path="system.decorum" data-object="actor"
      data-action="customEdit" {{doCheckIf system.decorum 'eq' 1}}>
  </div>

  <div class=" decorum-text  ">
    <span class="custom-system-label-root">
      <div class="custom-system-label-icons"></div>
      <label for="decorum_2-{{id}}" class="custom-system-label custom-system-label-label" data-value="Shabby"
        data-name="">{{localize
        "HOUSEHOLD.Decorum.Shabby"}}</label>
    </span>
  </div>

  <div class="decorum_3 decorum">
    <input type="radio" class="no-decor" id="decorum_3-{{id}}" data-dtype="Number"
      {{doCheckIf system.decorum 'eq' 3}} data-value="3" data-path="system.decorum"
      data-object="actor" data-action="customEdit">
  </div>

  <div class=" decorum-text  ">
    <span class="custom-system-label-root">
      <div class="custom-system-label-icons"></div>
      <label for="decorum_4-{{id}}" class="custom-system-label custom-system-label-label" data-value="Elegant"
        data-name="">{{localize
        "HOUSEHOLD.Decorum.Elegant"}}</label>
    </span>
  </div>

  <div class=" decorum_5 decorum  ">
    <input type="radio" class="no-decor" id="decorum_5-{{id}}" data-dtype="Number"
      data-value="5" data-path="system.decorum" data-object="actor"
      data-action="customEdit" {{doCheckIf system.decorum 'gteq' 5}}>
  </div>

  <div class=" decorum-text  ">
    <span class="custom-system-label-root">
      <div class="custom-system-label-icons"></div>
      <label for="decorum_1-{{id}}" class="custom-system-label custom-system-label-label" data-value="Uncouth"
        data-name="">{{localize
        "HOUSEHOLD.Decorum.Uncouth"}}</label>
    </span>
  </div>

  <div class=" decorum_2 decorum  ">
    <input type="radio" class="no-decor" id="decorum_2-{{id}}" data-dtype="Number"
      data-value="2" data-path="system.decorum" data-object="actor"
      data-action="customEdit" {{doCheckIf system.decorum 'eq' 2}}>
  </div>

  <div class=" decorum-text  ">
    <span class="custom-system-label-root">
      <div class="custom-system-label-icons"></div>
      <label for="decorum_3-{{id}}" class="custom-system-label custom-system-label-label" data-value="Decent"
        data-name="">{{localize
        "HOUSEHOLD.Decorum.Decent"}}</label>
    </span>
  </div>

  <div class=" decorum_4 decorum  ">
    <input type="radio" class="no-decor" id="decorum_4-{{id}}" data-dtype="Number"
      data-value="4" data-path="system.decorum" data-object="actor"
      data-action="customEdit" {{doCheckIf system.decorum 'eq' 4}}>
  </div>

  <div class=" decorum-text  ">
    <span class="custom-system-label-root">
      <div class="custom-system-label-icons"></div>
      <label for="decorum_5-{{id}}" class="custom-system-label custom-system-label-label" data-value="Pompous"
        data-name="">{{localize
        "HOUSEHOLD.Decorum.Pompous"}}</label>
    </span>
  </div>
</div>


<!-- Terrible Terrible Things -->
<h2 class="characteristic-title">{{localize "HOUSEHOLD.TTT.long"}}</h2>
<div class="flexrow">
  {{#numLoop 5}}

  {{#when ../system.ttt 'gteq' this}}
  <input class="input-hidden" type="radio" id="ttt-{{this}}-{{../id}}" data-value="{{reduceBy this 1}}"
    data-dtype="Number" data-path="system.ttt" data-object="actor" data-action="customEdit">
  <div class="ttt-icon">
    <label style=" align-items: center;" for="ttt-{{this}}-{{../id}}">
      <img class="custom-edit" width="28" height="28" style="border: 0px"
        src="/systems/household/assets/sheet/ttt{{this}}-filled.svg" data-value="{{reduceBy this 1}}"
        data-dtype="Number" data-path="system.ttt">
    </label>
  </div>
  {{else}}
  <input class="input-hidden" type="radio" id="ttt-{{this}}-{{../id}}" data-value="{{this}}" data-dtype="Number"
    data-path="system.ttt" data-object="actor" data-action="customEdit">
  <div class="ttt-icon">

    <label style=" align-items: center;" for="ttt-{{this}}-{{../id}}">
      <img class="custom-edit" width="28" height="28" data-value="{{this}}" data-dtype="Number" data-path="system.ttt"
        style="border: 0px" src="/systems/household/assets/sheet/ttt{{this}}.svg">
    </label>
  </div>
  {{/when}}
  {{/numLoop}}
</div>

<!-- conditions -->
<h2 class="characteristic-title" style="text-align: center;">{{localize "HOUSEHOLD.Conditions.long"}}</h2>
<div class="conditions-grid flex-group-center">
  <!-- embarrassed -->
  <div>
    <input type="checkbox" class="fa-household-heart{{#if system.conditions.embarrassed}}-full{{/if}} no-decor"
      id="condition-embarrassed-{{id}}" data-action="customEdit" data-path="system.conditions.embarrassed"
      data-value="{{system.conditions.embarrassed}}" data-object="actor" data-dtype="Boolean" {{doCheck
      system.conditions.embarrassed}}>
