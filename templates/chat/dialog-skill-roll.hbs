<div class="household dialog-skill-roll" data-actor-id="{{ actor.id }}">
    <div class="skill-details">
        {{#if skill}}
        <h2 class="skill-name">{{ skill.label }}</h2>
        <input style="display: none" value="{{skill_key}}" id="skill" name="skill" />
        <div class="value-display">
            <i class="suit-icon fa-household-{{skill.suit}}-full" alt="{{field}}" ></i>
            <span>x{{skill.value}}</span>
        </div>
        {{else}}
        <select class="skill-select-dropdown" style="max-width: 160px;">
            <option value="">{{localize "HOUSEHOLD.DialogTitles.SelectSkill"}}</option>
            {{#each actor.system.skills as |sk key|}}
            <option class="skill-option-item" data-key="{{key}}" value="{{key}}">
                <span class="skill-option-label">{{sk.label}}</span>
                <!--span class="skill-option-value">x{{sk.value}}</span-->
            </option>
            {{/each}}

            <input style="display: none" value="0" id="skill" name="skill" />
            <div class="value-display">
                 <i class="suit-icon fa-household-none" alt="{{field}}" ></i>
                <span>x0</span>
            </div>
            {{/if}}
    </div>


    <h3 class="characteristic-title-dialog">{{localize "HOUSEHOLD.ChooseField.long" }}</h3>
    <div class="display-fields">
        {{#each fields as |fd key|}}
        <div>
            <input type="radio" class="toggle-input field-option field field-{{key}} no-decor" data-key="{{key}}"
                id="choose-{{key}}-{{@root/actor.id}}" name="field" value="{{key}}" {{#when key 'eq'
                @root/field}}checked{{/when}} />
            <label class="field-label" for="choose-{{key}}-{{@root/actor.id}}">
                <span>x{{fd.value}}</span>
            </label>
        </div>
        {{/each}}
    </div>

